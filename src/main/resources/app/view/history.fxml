<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="app.controller.HistoryController"
      fx:id="root"
      spacing="10.0">
    <padding>
        <Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/>
    </padding>

    <Label text="Commit History" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <TableView fx:id="commitTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="hashCol" text="Hash" prefWidth="80"/>
            <TableColumn fx:id="dateCol" text="Date" prefWidth="150"/>
            <TableColumn fx:id="authorCol" text="Author" prefWidth="100"/>
            <TableColumn fx:id="messageCol" text="Message" prefWidth="250"/>
        </columns>
    </TableView>

    <HBox spacing="8.0">
        <Button text="Refresh" onAction="#onRefresh"/>
    </HBox>
</VBox>
