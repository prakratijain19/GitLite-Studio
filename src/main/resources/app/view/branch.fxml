<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="app.controller.BranchController"
      fx:id="root"
      spacing="10.0">
    <padding>
        <Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/>
    </padding>

    <Label text="Branches" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <ListView fx:id="branchList" VBox.vgrow="ALWAYS"/>

    <HBox spacing="8.0">
        <Button text="Checkout Selected" onAction="#onCheckout"/>
        <Button text="Refresh" onAction="#onRefresh"/>
    </HBox>

    <HBox spacing="8.0" alignment="CENTER_LEFT">
        <TextField fx:id="newBranchField" promptText="New branch name" HBox.hgrow="ALWAYS"/>
        <Button text="Create Branch" onAction="#onCreateBranch"/>
    </HBox>
</VBox>
