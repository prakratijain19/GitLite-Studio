<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="app.controller.DiffController"
      fx:id="root"
      spacing="10.0">
    <padding>
        <Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/>
    </padding>

    <Label fx:id="titleLabel" text="Diff Viewer" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label fx:id="pathLabel" text="File: (none)" style="-fx-font-size: 14px;"/>

    <ListView fx:id="diffList" style="-fx-font-family: 'monospaced';" VBox.vgrow="ALWAYS"/>
</VBox>
